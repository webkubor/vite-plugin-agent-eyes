{
  "name": "vite-plugin-agent-eyes",
  "version": "0.5.0",
  "description": "给 AI agent 的自愈遥测层：结构化运行时日志（API/错误/代理 header）+ 本地 cookie 修复，让 agent 自我诊断、自我修复。Agent-readable runtime telemetry for Vite dev.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/webkubor/vite-plugin-agent-eyes.git"
  },
  "keywords": [
    "vite",
    "vite-plugin",
    "ai-agent",
    "debugging",
    "telemetry",
    "self-healing",
    "proxy",
    "cookie",
    "git-hooks",
    "pre-commit",
    "webhook"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/client.ts --format esm --dts --clean",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "vite": ">=4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/ws": "^8.18.1",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.0.0"
  },
  "dependencies": {
    "ws": "^8.21.0"
  }
}
