{
  "name": "vite-plugin-agent-eyes",
  "version": "0.10.1",
  "description": "给 AI agent 的自愈遥测层：结构化运行时日志（API/错误/交互/代理 header）+ 本地 cookie 修复 + 登录态画像 + 提交前风险门禁。Agent-readable runtime telemetry, interaction traces, auth profile hints, and pre-commit guard for Vite dev.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/webkubor/vite-plugin-agent-eyes.git"
  },
  "keywords": [
    "vite",
    "vite-plugin",
    "ai-agent",
    "debugging",
    "telemetry",
    "self-healing",
    "proxy",
    "cookie",
    "auth",
    "interaction-trace",
    "git-hooks",
    "pre-commit",
    "guard",
    "webhook"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "SKILL.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/client.ts --format esm --dts --clean",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run",
    "build:tmp": "tsup src/index.ts src/client.ts --format esm --dts --clean --out-dir .tmp/vite-plugin-agent-eyes-build",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "vite": ">=4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/ws": "^8.18.1",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.0.0",
    "vitest": "^3.2.0"
  },
  "dependencies": {
    "ws": "^8.21.0"
  }
}
